
@php
  // Normalizar níveis (remover espaços e lowercase)
  $competitorsList = collect($competitors ?? []);
  
  $categoryCounts = [
    'todos' => $competitorsList->count(),
    'favorito' => $competitorsList->filter(fn($c) => strtolower(preg_replace('/\s+/', '', $c->nivel ?? '')) === 'favorito')->count(),
    'elite' => $competitorsList->filter(fn($c) => strtolower(preg_replace('/\s+/', '', $c->nivel ?? '')) === 'elite')->count(),
    'ascendente' => $competitorsList->filter(fn($c) => in_array(strtolower(preg_replace('/\s+/', '', $c->nivel ?? '')), ['ascendente', 'legado']))->count(),
    'competidor' => $competitorsList->filter(fn($c) => in_array(strtolower(preg_replace('/\s+/', '', $c->nivel ?? '')), ['competidor', 'presilha']))->count(),
  ];
  
  $rrCategories = [
    ['label' => 'Todos', 'key' => 'todos', 'meta' => 'Ver todos'],
    ['label' => 'Favorito', 'key' => 'favorito', 'meta' => 'Top competidores'],
    ['label' => 'Elite', 'key' => 'elite', 'meta' => 'Mais populares'],
    ['label' => 'Ascendente', 'key' => 'ascendente', 'meta' => 'Profissionais'],
    ['label' => 'Competidor', 'key' => 'competidor', 'meta' => 'Alto nível'],
  ];
@endphp

