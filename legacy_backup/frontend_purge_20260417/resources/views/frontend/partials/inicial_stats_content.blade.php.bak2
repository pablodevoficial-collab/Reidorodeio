<div class="rr-cards-list" id="rrCardsGrid" style="position: relative !important; z-index: 0 !important; overflow: visible !important;">
  @foreach($competitors as $c)
    @php
      $hidePoints = (bool) ($hidePoints ?? false);
      $stats = $c->stats;
      $vitorias = (int)($stats->vitorias ?? 0);
      $empates = (int)($stats->empates ?? 0);
      $derrotas = (int)($stats->derrotas ?? 0);
      $pontuacaoTotal = (int)($stats->pontuacao_total ?? 0);
      $boas = (int)($stats->count_boa ?? 0);
      $negTot = (int)($stats->count_negativas_total ?? 0);
      // Armadas = somente BOA (positiva) ou ERRO (qualquer negativa).
      $armadasTotalRaw = $boas + $negTot;
      $armadasTotal = $armadasTotalRaw;
      $armadasTotalPctDen = max(1, $armadasTotalRaw);
      $armadasPct = (int) round(($boas / $armadasTotalPctDen) * 100);
      $lastPoints = (int) ($stats->last_points ?? 0);
      $lastColor = $lastPoints > 0 ? 'style="color:#00e676"' : ($lastPoints < 0 ? 'style="color:#ff5252"' : '');

      // Destrezas = pontuações positivas extras (não contam como armada em si).
      $destrezasTotal = 0;
      $destrezasTotal += (int)($stats->count_limpou_garupa ?? 0);
      $destrezasTotal += (int)($stats->count_cola ?? 0);
      $destrezasTotal += (int)($stats->count_cupim ?? 0);
      $destrezasTotal += (int)($stats->count_top ?? 0);
      $destrezasTotal += (int)($stats->count_pescou ?? 0);
      $destrezasTotal += (int)($stats->count_limpou_cupim_longe ?? 0);
      $destrezasTotal += (int)($stats->count_pescou_uma_aspa ?? 0);
      $destrezasTotal += (int)($stats->count_limpou_top ?? 0);
      $destrezasTotal += (int)($stats->count_limpou_top_mao ?? 0);

      if ($hidePoints) {
        $pontuacaoTotal = 0;
        $lastPoints = 0;
        $lastColor = '';
      }
      $pctMedia = (int)round(min(100, max(0, $stats->pontuacao_media ?? 0)));
      $nivelKey = strtolower(preg_replace('/\s+/', '', (string)($c->nivel ?? '')));

      // Foto do competidor usando o accessor do model
      $fotoUrl = $c->foto_url;

      // Cores por categoria
      $colorMap = [
        'favorito' => 'hsl(43, 100%, 50%)',   // Dourado
        'elite' => 'hsl(357, 100%, 49%)', // Vermelho
        'legado' => 'hsl(220, 10%, 70%)',    // Prateado
        'presilha' => 'hsl(145, 63%, 42%)',  // Verde
      ];
      $cardColor = $colorMap[$nivelKey] ?? 'hsl(25, 100%, 50%)'; // Laranja default

      $badgeMap = [
        'favorito' => '⭐',
        'elite' => '❤️',
        'legado' => '🏆',
        'presilha' => '🌱',
      ];
      $badge = $badgeMap[$nivelKey] ?? '🔥';
    @endphp
    @php
      // Extrair apenas os dois primeiros nomes
      $nomeCompleto = $c->nome ?? 'Sem nome';
      $partesNome = explode(' ', $nomeCompleto);
      $nomeCurto = isset($partesNome[0]) && isset($partesNome[1])
        ? $partesNome[0] . ' ' . $partesNome[1]
        : $partesNome[0] ?? 'Sem nome';
