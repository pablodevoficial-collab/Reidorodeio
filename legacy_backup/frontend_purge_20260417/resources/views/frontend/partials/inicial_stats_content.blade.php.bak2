          <img src="{{ $fotoUrl }}" alt="{{ $nomeCompleto }}" onerror="this.src='/assets/images/logo_icon/favicon.png'" style="width: 100% !important; height: 100% !important; border-radius: 50% !important; object-fit: cover !important; object-position: center top !important; display: block !important;">
