    #rrCardsGrid .premium-card__photo {
      width: 92px;
      height: 92px;
    }
    #rrCardsGrid .premium-card__name {
      font-size: clamp(0.78rem, 0.9vw, 0.95rem);
      min-height: 1.8rem;
    }
    #rrCardsGrid .premium-card__btn {
      font-size: clamp(0.64rem, 0.7vw, 0.72rem);
      padding: 0.3rem 0.6rem;
      border-radius: 6px;
    }
  }
</style>

<style>
  /* COMPETITOR HEX CARDS - Estilo Hexagonal - COMENTADO (substituído por holographic-cards.css)
  .rr-cards-list {
    display: grid !important;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)) !important;
    gap: 2rem 1rem !important;
    padding: 2rem 0 !important;
    justify-items: center;
  }

  .rr-card-item {
    width: 100%;
    max-width: 220px;
  }

  /* Hexagonal Card */
  .hex-card {
    filter: drop-shadow(0px 0px 5px var(--card-color)) drop-shadow(0px 0px 15px var(--card-color));
    position: relative;
    max-width: 200px;
    margin: auto;
    font-family: inherit;
  }

  /* Ascendente: sombra branca especial */
  .rr-card-item[data-nivel="legado"] .hex-card {
    filter: drop-shadow(0px 0px 8px rgba(255,255,255,0.7)) drop-shadow(0px 0px 20px rgba(255,255,255,0.5));
  }

  .hex-card__border,
  .hex-card__border-line,
  .hex-card__inner {
    clip-path: polygon(50% 0, 100% 20%, 100% 80%, 50% 100%, 0% 80%, 0% 20%);
  }

  .hex-card__border {
    position: absolute;
    width: 98%;
    height: 102%;
    background: var(--card-color);
    left: 1%;
    top: 1%;
  }

  .hex-card__border-line {
    position: absolute;
    width: 95%;
    height: 99%;
    left: 2.5%;
    top: 2.5%;
    background: linear-gradient(to bottom, hsl(42, 90%, 72%) 33%, hsl(0, 0%, 0%) 70%);
  }

  /* Ascendente: gradiente prateado */
  .rr-card-item[data-nivel="legado"] .hex-card__border-line {
    background: linear-gradient(to bottom, hsl(220, 15%, 85%) 33%, hsl(220, 10%, 20%) 70%);
  }

  .rr-card-item[data-nivel="legado"] .hex-card__inner {
    background: linear-gradient(179deg, hsl(220, 10%, 70%), hsl(220, 10%, 50%) 90%);
  }

  .hex-card__inner {
    background: linear-gradient(179deg, var(--card-color), #e3a83b 90%);
    padding: 0.4rem 0.15rem 0;
    width: 92%;
    margin-top: 4.8%;
    margin-left: 4%;
  }

  .hex-card__img {
    display: flex;
    padding: 0 0.5rem;
    background: repeating-linear-gradient(126deg,
                hsla(0, 0%, 100%, 0.219) 0%,
                #ffffff57 1.2%,
                transparent 1.19%,
                transparent 4%);
    position: relative;
    justify-content: center;
    min-height: 100px;
  }

  .hex-card__badge {
    position: absolute;
    top: 5px;
    left: 5px;
    font-size: 1.2rem;
    z-index: 2;
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.5));
  }

  .hex-card__athlete {
    flex: 1;
    padding-top: 8%;
    display: flex;
    justify-content: center;
    align-items: flex-end;
    overflow: hidden;
  }

  .hex-card__athlete img {
    width: 90%;
    max-height: 100px;
    object-fit: cover;
    object-position: top center;
    border-radius: 4px;
  }

  .hex-card__text {
    position: relative;
    /* Reserve space so the button can sit at the bottom */
    padding: 0.5rem 0.5rem 3.4rem;
    text-align: center;
    background: rgba(0,0,0,0.1);
  }

  .hex-card__text:before {
    content: '';
    position: absolute;
    inset: 0;
    background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><rect fill="%23d4a574" width="100" height="100"/></svg>');
    opacity: 0.15;
    z-index: -1;
  }

  .hex-card__type {
    width: min-content;
    margin: -8% auto 0.3rem;
    padding: 2px 12px;
    border-radius: 4px;
    background: var(--bg-color);
    color: #000;
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .hex-card__name {
    font-size: 1rem;
    font-weight: 800;
    margin: 0 0 0.2rem;
    color: #000;
    text-transform: uppercase;
    line-height: 1.1;
    position: relative;
  }

  .hex-card__name:before {
    content: '';
    background: linear-gradient(to right, transparent, #3730305c, black, #0000004f, transparent);
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 2px;
  }

  .hex-card__points {
    font-size: 1.4rem;
    font-weight: 800;
    margin: 0.3rem 0 0.2rem;
    color: #000;
    position: relative;
  }

  .hex-card__points:before {
    content: "";
    position: absolute;
    left: 50%;
    bottom: -2px;
    transform: translateX(-50%);
    width: 30%;
    height: 2px;
    background: black;
  }

  .hex-card__stats {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 0.4rem;
    font-size: 0.65rem;
    font-weight: 600;
    color: #333;
  }

  .hex-card__stat {
    background: rgba(0,0,0,0.1);
    padding: 2px 6px;
    border-radius: 3px;
  }

  .hex-card__actions {
    position: absolute;
    left: -0.5rem;
    right: -0.5rem;
    bottom: 0.15rem;
    margin: 0;
    z-index: 3;
  }

  .hex-card__btn {
    display: block;
    width: 100%;
    background: rgba(0,0,0,0.78);
    border: 1px solid rgba(255,255,255,0.18);
    color: #fff;
    padding: 8px 0 9px;
    border-radius: 0;
    font-size: 0.78rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    letter-spacing: 0.2px;
    clip-path: polygon(0 0, 100% 0, 92% 58%, 50% 100%, 8% 58%);
  }

  .hex-card__btn:hover {
    background: rgba(0,0,0,0.92);
    border-color: rgba(255,255,255,0.28);
  }

  /* Mobile: 3 colunas (PREMIUM CARDS) */
  @media (max-width: 767.98px) {
    .rr-cards-list {
      grid-template-columns: repeat(3, 1fr) !important;
      gap: 1rem !important;
      padding: 1rem 0.8rem !important;
    }
  }

  /* Tablet: 3 colunas (PREMIUM CARDS) */
  @media (min-width: 768px) and (max-width: 991.98px) {
    .rr-cards-list {
      grid-template-columns: repeat(4, 1fr) !important;
      gap: 1.5rem !important;
    }
  }

  /* Desktop: mais colunas (PREMIUM CARDS) */
  @media (min-width: 992px) {
    .rr-cards-list {
      grid-template-columns: repeat(5, 1fr) !important;
      gap: 2rem !important;
    }
  }

  END OF HEX CARDS CSS - COMENTADO */

  /* Searchbar Animada (estilo X1 moderno) */
  .rr-stats-search-wrapper {
    max-width: 500px;
    margin: 0 auto;
    padding: 0.6rem 0;
    position: relative;
    z-index: 100;
  }

  .rr-stats-search-wrapper--inline {
    max-width: 260px;
    flex: 0 0 auto;
  }

  .rr-stats-search-form {
    position: relative;
    width: 48px;
    height: 48px;
    margin: 0 auto;
    transition: width 0.36s cubic-bezier(0.2, 0.9, 0.2, 1), box-shadow 0.36s ease, background 0.36s ease;
    border-radius: 24px;
  }

  .rr-stats-search-wrapper--inline .rr-stats-search-form {
    margin: 0;
  }

  .rr-stats-search-wrapper--inline .rr-stats-search-form.is-open {
    width: 260px;
  }

  .rr-stats-search-form.is-open {
    width: 100%;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
  }

  .rr-stats-search-form input {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: transparent;
    border: none;
    outline: none;
    color: #e2e8f0;
    font-size: 0.95rem;
    padding: 0 60px 0 20px;
    border-radius: 24px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .rr-stats-search-form.is-open input {
    opacity: 1;
    pointer-events: all;
  }

  .rr-stats-search-form input::placeholder {
    color: rgba(255, 255, 255, 0.4);
  }

  .rr-stats-search-icon {
    position: absolute;
    right: 0;
    top: 0;
    width: 48px;
    height: 48px;
    background: linear-gradient(135deg, #f97316, #fb923c);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    z-index: 10;
    box-shadow: 0 2px 10px rgba(249, 115, 22, 0.4);
  }

  .rr-stats-search-form.is-open .rr-stats-search-icon {
    background: rgba(249, 115, 22, 0.18);
    box-shadow: 0 6px 26px rgba(249, 115, 22, 0.12);
    transform: translateX(-6px);
  }

  .rr-stats-search-icon svg {
    width: 20px;
    height: 20px;
    color: white;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    transition: all 0.3s ease;
  }

  .rr-stats-search-icon .icon-search {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1) rotate(0deg);
  }

  .rr-stats-search-icon .icon-close {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0) rotate(180deg);
  }

  .rr-stats-search-form.is-open .rr-stats-search-icon .icon-search {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0) rotate(-180deg);
  }

  .rr-stats-search-form.is-open .rr-stats-search-icon .icon-close {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1) rotate(0deg);
  }

  .rr-stats-search-icon:hover {
    transform: scale(1.06);
    box-shadow: 0 6px 20px rgba(249, 115, 22, 0.55);
  }

  .rr-stats-search-form.is-open .rr-stats-search-icon:hover {
    box-shadow: 0 8px 26px rgba(249, 115, 22, 0.12);
    transform: translateX(-6px) scale(1.04);
  }

  @media (max-width: 768px) {
    .rr-stats-search-wrapper {
      max-width: 100%;
      padding: 0.75rem 0;
    }
    .rr-stats-search-form {
      width: 40px;
      height: 40px;
    }
    .rr-stats-search-icon {
      width: 40px;
      height: 40px;
    }
    .rr-stats-search-icon svg {
      width: 18px;
      height: 18px;
    }
  }

  /* Paginação estilizada */
  .rr-pagination {
    margin-top: 2rem !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    gap: 0.75rem !important;
  }

  .rr-pagination .btn {
    min-width: 100px !important;
    font-weight: 600 !important;
    transition: all 0.3s ease !important;
  }

  .rr-pagination .btn:disabled {
    opacity: 0.4 !important;
  }

  .rr-pagination .btn:not(:disabled):hover {
    transform: translateY(-2px) !important;
  }

  #pageIndicator {
    font-weight: 700 !important;
    font-size: 1rem !important;
    color: #FF6B35 !important;
    padding: 0.5rem 1rem !important;
    background: rgba(255,107,53,0.1) !important;
    border-radius: 8px !important;
  }

  /* Row para Search + Submenu (mesmo estilo do X1) */
  .rr-stats-submenu-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: nowrap;
  }

   /* Desktop: submenu centralizado e lupa à esquerda */
   @media (min-width: 769px) {
     .rr-stats-submenu-row {
       justify-content: center;
       position: relative;
       max-width: 520px;
       margin: 0 auto;
     }

     .rr-stats-submenu-row .rr-stats-search-wrapper--inline {
       position: absolute;
       left: -280px;
     }

     .rr-stats-submenu-row .rr-epic-submenu {
       margin: 0 auto;
       width: 100%;
     }
   }

  .rr-stats-submenu-row .rr-stats-search-wrapper {
    margin: 0;
  }

   @media (max-width: 768px) {
     .rr-stats-submenu-row {
       flex-direction: column;
       gap: 0.75rem;
     }

     .rr-stats-submenu-row .rr-stats-search-wrapper--inline {
       order: 2;
     }

     .rr-stats-submenu-row .rr-epic-submenu {
       order: 1;
     }

     .rr-stats-search-wrapper--inline {
       width: 100%;
       max-width: 240px;
     }

     .rr-stats-search-wrapper--inline .rr-stats-search-form {
       margin: 0 auto;
     }

    .rr-stats-search-wrapper--inline .rr-stats-search-form.is-open {
      width: 100%;
    }
  }

  .rr-stats-submenu-row .rr-epic-submenu {
    margin: 0 auto;
    width: 100%;
  }

</style>
<style>
  /* Paginação em laranja e animação */
  .rr-pagination {
    gap: 0.5rem;
  }
  .rr-pagination .btn {
    background: linear-gradient(135deg, #f97316, #fb923c);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: #fff;
    transition: transform 0.2s ease, box-shadow 0.2s ease, opacity 0.2s ease;
    border-radius: 999px;
    padding: 0.35rem 0.9rem;
    box-shadow: 0 6px 18px rgba(249, 115, 22, 0.25);
  }
  .rr-pagination .btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
    box-shadow: none;
  }
  .rr-pagination .btn:not(:disabled):hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 22px rgba(249, 115, 22, 0.35);
  }
  #pageIndicator {
    margin: 0 0.6rem;
    color: #f97316;
    font-weight: 800;
    letter-spacing: 0.4px;
    min-width: 70px;
    text-align: center;
    transition: opacity 0.3s ease;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-5px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .page-updated {
    animation: fadeIn 0.4s ease-out;
  }
</style>
<script>
  // ========== CONTROLE DE TABS PRINCIPAIS ==========
  (function() {
    const mainTabs = document.querySelectorAll('.rr-stats-main-tab');
    const tabContents = document.querySelectorAll('.rr-stats-tab-content');
    
    mainTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const targetTab = tab.dataset.tab;
        
        // Remove active de todas as tabs
        mainTabs.forEach(t => t.classList.remove('rr-stats-main-tab--active'));
        tabContents.forEach(c => {
          c.classList.remove('rr-stats-tab-content--active');
          c.style.display = 'none';
        });
        
        // Ativa a tab clicada
        tab.classList.add('rr-stats-main-tab--active');
        const targetContent = document.getElementById(`rrStatsTab${targetTab.charAt(0).toUpperCase() + targetTab.slice(1)}`);
        if (targetContent) {
          targetContent.style.display = 'block';
          targetContent.classList.add('rr-stats-tab-content--active');
        }
      });
    });
  })();
  
  // ========== NAVEGAÇÃO DE EVENTOS ==========
  (function() {
    const eventStatsByCompetitor = @json($eventStatsByCompetitor ?? []);
    const eventLookup = @json($eventLookup ?? []);
    const modalidadeLookup = @json($modalidadeLookup ?? []);
    
    // Agrupar dados por evento
    const eventoData = {};
    Object.entries(eventStatsByCompetitor).forEach(([compId, events]) => {
      events.forEach(evt => {
        const rodeioId = evt.rodeio_id;
        const modalidadeId = evt.modalidade_id || 0;
        
        if (!eventoData[rodeioId]) {
          eventoData[rodeioId] = {
            nome: eventLookup[rodeioId] || `Rodeio #${rodeioId}`,
            modalidades: {}
          };
        }
        
        if (!eventoData[rodeioId].modalidades[modalidadeId]) {
          eventoData[rodeioId].modalidades[modalidadeId] = {
            nome: modalidadeLookup[modalidadeId] || 'N/A',
            stats: []
          };
        }
        
        eventoData[rodeioId].modalidades[modalidadeId].stats.push(evt);
      });
    });
    
    // Click em card de evento
    document.querySelectorAll('.rr-event-card').forEach(card => {
      card.addEventListener('click', () => {
        const rodeioId = parseInt(card.dataset.rodeioId);
        const rodeioNome = card.dataset.rodeioNome;
        showEventModalidades(rodeioId, rodeioNome);
      });
    });
    
    function showEventModalidades(rodeioId, rodeioNome) {
      const eventsGrid = document.getElementById('rrEventsGrid');
      const modalidadesSection = document.getElementById('rrEventModalidades');
      const titleEl = document.getElementById('rrEventModalidadesTitle');
      const gridEl = document.getElementById('rrModalidadesGrid');
      
      if (!eventoData[rodeioId]) return;
      
      eventsGrid.style.display = 'none';
      modalidadesSection.style.display = 'block';
      titleEl.textContent = rodeioNome;
      
      // Renderizar modalidades
      const modalidades = eventoData[rodeioId].modalidades;
      gridEl.innerHTML = Object.entries(modalidades).map(([modalidadeId, data]) => {
        const totalPontos = data.stats.reduce((acc, s) => acc + s.pontuacao_total, 0);
        const totalParticipacoes = data.stats.length;
        
        return `
          <div class="rr-modalidade-card" data-rodeio-id="${rodeioId}" data-modalidade-id="${modalidadeId}">
            <h6 class="rr-modalidade-card__title">${data.nome}</h6>
            <div class="rr-modalidade-card__stats">
              <span>${totalParticipacoes} participações</span>
              <span>${totalPontos} pts</span>
            </div>
          </div>
        `;
      }).join('');
      
      // Adicionar listeners nos cards de modalidade
      gridEl.querySelectorAll('.rr-modalidade-card').forEach(card => {
        card.addEventListener('click', () => {
          const modalidadeId = parseInt(card.dataset.modalidadeId);
          showModalidadeStats(rodeioId, rodeioNome, modalidadeId);
        });
      });
    }
    
    function showModalidadeStats(rodeioId, rodeioNome, modalidadeId) {
      const modalidadesSection = document.getElementById('rrEventModalidades');
      const statsSection = document.getElementById('rrModalidadeStats');
      const titleEl = document.getElementById('rrModalidadeStatsTitle');
      const detailsEl = document.getElementById('rrModalidadeStatsDetails');
      
      const modalidadeData = eventoData[rodeioId]?.modalidades[modalidadeId];
      if (!modalidadeData) return;
      
      modalidadesSection.style.display = 'none';
      statsSection.style.display = 'block';
      titleEl.textContent = `${rodeioNome} - ${modalidadeData.nome}`;
      
      // Agregar estatísticas
      const stats = modalidadeData.stats.reduce((acc, s) => ({
        pontuacao_total: acc.pontuacao_total + s.pontuacao_total,
        count_boa: acc.count_boa + s.count_boa,
        count_negativas_total: acc.count_negativas_total + s.count_negativas_total,
        participacoes: acc.participacoes + 1
      }), { pontuacao_total: 0, count_boa: 0, count_negativas_total: 0, participacoes: 0 });
      
      const totalArmadas = Math.max(1, stats.count_boa + stats.count_negativas_total);
      const aproveitamento = Math.round((stats.count_boa / totalArmadas) * 100);
      
      detailsEl.innerHTML = `
        <div class="rr-stats-detail-card">
          <div class="rr-stats-detail-card__header">
            <span class="rr-stats-detail-card__title">Pontuação Total</span>
            <span class="rr-stats-detail-card__value">${stats.pontuacao_total}</span>
          </div>
        </div>
        <div class="rr-stats-detail-card">
          <div class="rr-stats-detail-card__header">
            <span class="rr-stats-detail-card__title">Aproveitamento</span>
            <span class="rr-stats-detail-card__value">${aproveitamento}%</span>
          </div>
          <div class="rr-stats-detail-card__meta">
            <span style="color: #00e676;">${stats.count_boa} boas</span>
            <span style="color: #ff5252;">${stats.count_negativas_total} erros</span>
          </div>
        </div>
        <div class="rr-stats-detail-card">
          <div class="rr-stats-detail-card__header">
            <span class="rr-stats-detail-card__title">Participações</span>
            <span class="rr-stats-detail-card__value">${stats.participacoes}</span>
          </div>
        </div>
      `;
    }
    
    // Botão voltar aos eventos
    document.getElementById('rrBtnBackToEvents')?.addEventListener('click', () => {
      document.getElementById('rrEventsGrid').style.display = 'grid';
      document.getElementById('rrEventModalidades').style.display = 'none';
    });
    
    // Botão voltar às modalidades
    document.getElementById('rrBtnBackToModalidades')?.addEventListener('click', () => {
      document.getElementById('rrEventModalidades').style.display = 'block';
      document.getElementById('rrModalidadeStats').style.display = 'none';
    });
  })();
</script>

<script>
  // Mobile filter + 3x3 pagination (9 por página)
  (function(){
    const inHub = !!document.getElementById('hubSection');
    if (inHub || window.__RRStatsBound) return;
    window.__RRStatsBound = true;
    const grid = document.getElementById('rrCardsGrid');
    if (!grid) return;
    const items = Array.from(grid.querySelectorAll('.rr-card-item'));
    // Paginação desktop
    let currentPage = 1;
    let totalPages = 1;
    const isMobile = () => window.matchMedia('(max-width: 575.98px)').matches;
    const isTablet = () => window.matchMedia('(min-width: 576px) and (max-width: 991.98px)').matches;
    let currentFilter = 'todos';
    let searchTerm = '';

    function applyFilter(filter){
      currentFilter = filter;
      items.forEach(el => {
        const niv = (el.getAttribute('data-nivel')||'').toLowerCase();
        const nome = (el.querySelector('.premium-card__name')?.textContent || '').toLowerCase();

        // Combina filtro de categoria + busca
      const normalizedFilter = (filter || '').toLowerCase();
      const matchesCategory = (normalizedFilter==='todos') || (niv === normalizedFilter);
        const matchesSearch = !searchTerm || nome.includes(searchTerm.toLowerCase());
        const visible = matchesCategory && matchesSearch;

        el.style.display = visible ? '' : 'none';
      });
      currentPage = 1; // Volta para primeira página
      paginate();
    }

    function applySearch() {
      applyFilter(currentFilter); // Reaplica com termo de busca
    }

    function paginate(){
      const visible = items.filter(el => el.style.display !== 'none');

      // Define items por página baseado na tela
      let perPage;
      if (isMobile()) {
        perPage = 40; // 2 colunas x 20 linhas
      } else if (isTablet()) {
        perPage = 40; // 5 colunas x 8 linhas
      } else {
        perPage = 40; // Desktop: 10 colunas x 4 linhas
      }

      totalPages = Math.max(1, Math.ceil(visible.length / perPage));
      currentPage = Math.min(currentPage, totalPages);

      // Mostra apenas items da página atual
      visible.forEach((el, i) => {
        const onCurrentPage = i >= (currentPage - 1) * perPage && i < currentPage * perPage;
        el.hidden = !onCurrentPage;
      });

      // Atualiza controles de navegação
      const prevBtn = document.getElementById('prevPageBtn');
      const nextBtn = document.getElementById('nextPageBtn');
      const pageIndicator = document.getElementById('pageIndicator');

      if (prevBtn && nextBtn && pageIndicator) {
        pageIndicator.textContent = `${currentPage} / ${totalPages}`;
        pageIndicator.style.transition = 'all 0.3s ease';

        prevBtn.disabled = currentPage <= 1;
        nextBtn.disabled = currentPage >= totalPages;

        // Mostra paginação apenas se tiver mais de 1 página
        const pagination = document.querySelector('.rr-pagination');
        if (pagination) {
          pagination.style.display = totalPages > 1 ? 'flex' : 'none';
        }
      }

      // Scroll suave para o topo do grid ao mudar página
      if (grid && currentPage > 1) {
        grid.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }

    // Eventos de paginação
    document.getElementById('prevPageBtn')?.addEventListener('click', () => {
      if (currentPage > 1) {
        currentPage--;
        paginate();
      }
    });

    document.getElementById('nextPageBtn')?.addEventListener('click', () => {
      if (currentPage < totalPages) {
        currentPage++;
        paginate();
      }
    });

    // Filtros - agora usando o submenu épico
    document.querySelectorAll('#rrStatsSubmenu .rr-epic-submenu__btn[data-filter]')?.forEach(card => {
      card.addEventListener('click', function(){
        document.querySelectorAll('#rrStatsSubmenu .rr-epic-submenu__btn').forEach(c=>c.classList.remove('is-active'));
        this.classList.add('is-active');
        let filter = this.getAttribute('data-filter');
        filter = (filter || '').toLowerCase();
        if (filter === 'legado') filter = 'ascendente';
        if (filter === 'presilha') filter = 'competidor';
        applyFilter(filter || 'todos');
      });
    });

    // Barra de pesquisa animada com ícone que alterna lupa/X (estilo X1)
    const searchInput = document.getElementById('rrStatsSearchInput');
    const searchForm = document.getElementById('rrStatsSearchForm');
    const searchIcon = document.getElementById('rrStatsSearchIcon');
    let isSearchOpen = false;

    function openSearch() {
      isSearchOpen = true;
      searchForm.classList.add('is-open');
      setTimeout(() => searchInput.focus(), 300);
    }

    function closeSearch() {
      isSearchOpen = false;
      searchInput.value = '';
      searchTerm = '';
      searchInput.blur(); // Fecha teclado no mobile
      searchForm.classList.remove('is-open');
      applySearch(); // Reseta a lista
    }

    if (searchIcon) {
      searchIcon.addEventListener('click', function(e) {
        e.stopPropagation();
        if (isSearchOpen) {
          closeSearch();
        } else {
          openSearch();
        }
      });
    }

    if (searchInput) {
      searchInput.addEventListener('input', function() {
        searchTerm = this.value.trim();
        applySearch();
      });

      searchInput.addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
          e.preventDefault();
          applySearch();
        }
      });

      // ESC fecha a busca
      searchInput.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
          closeSearch();
        }
      });
    }

    // Clicar no form fechado abre a busca
    if (searchForm) {
      searchForm.addEventListener('click', function(e) {
        if (!isSearchOpen && !searchIcon.contains(e.target)) {
          openSearch();
        }
      });
    }

    // Reagir a resize
    window.addEventListener('resize', () => {
      paginate();
    });

    // Inicialização
    applyFilter('todos');

    // Flag premium para gating do botão "Ver todas"
    const IS_PREMIUM = Boolean(@json(auth()->check() && method_exists(auth()->user(), 'isPremium') ? auth()->user()->isPremium() : false));

    // Top-level 'Ver todas' button: premium => AJAX; free => modal de upgrade
    document.getElementById('rrTopVerTodas')?.addEventListener('click', function(){
      if (!IS_PREMIUM) {
        // Usuário não premium: direciona para modal/landing
        return handleVerTodas(0, '{{ route('premium.landing') }}');
      }

      // Premium: carrega a lista completa via query param na mesma rota
      window.location.href = '{{ route('inicio.stats') }}?all=1';
    });
  })();
  // Modal genérico para estatísticas e upgrade
