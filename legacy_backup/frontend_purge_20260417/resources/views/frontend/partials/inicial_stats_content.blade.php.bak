              </div>
            </div>
          </div>
        </div>
      </div>`;
    document.body.appendChild(el);
    return el;
  }

  function openRrModal(modalEl) {
    console.log('[DEBUG] [openRrModal] Abrindo modal...', modalEl);
    if (!modalEl) {
      console.error('[ERROR] [openRrModal] Modal element é NULL!');
      return;
    }
    // Backdrop
    let backdrop = document.getElementById('rrModalBackdrop');
    if (!backdrop) {
      console.log('[DEBUG] [openRrModal] Criando backdrop...');
      backdrop = document.createElement('div');
      backdrop.id = 'rrModalBackdrop';
      backdrop.className = 'modal-backdrop fade show';
      document.body.appendChild(backdrop);
    }

    modalEl.style.display = 'block';
    modalEl.classList.add('show');
    modalEl.setAttribute('aria-hidden', 'false');
    modalEl.setAttribute('role', 'dialog');
    modalEl.setAttribute('aria-modal', 'true');
    document.body.classList.add('modal-open');
    document.body.style.overflow = 'hidden';
    console.log('[OK] [openRrModal] Modal visível e backdrop adicionado');

    if (modalEl.id === 'competitorModal') {
      console.log('[DEBUG] [openRrModal] Configurando partículas do modal...');
      setupCompetitorModalParticles(modalEl);
    }

    if (!modalEl._rrBound) {
      modalEl._rrBound = true;

      // close button(s)
      modalEl.querySelectorAll('[data-rr-modal-close]').forEach(btn => {
        btn.addEventListener('click', () => closeRrModal(modalEl));
      });

      // click outside dialog
      modalEl.addEventListener('mousedown', (ev) => {
        if (ev.target === modalEl) closeRrModal(modalEl);
      });

      // premium CTA: close modal and open premium tab
      modalEl.addEventListener('click', (ev) => {
        const cta = ev.target.closest && ev.target.closest('[data-premium-open]');
        if (!cta) return;
        closeRrModal(modalEl);
        const premiumBtn = document.querySelector('.hub-mobile-tabbar__btn.premium');
        if (premiumBtn) {
          premiumBtn.click();
        } else {
          window.location.href = '{{ route('premium.landing') }}';
        }
      });

      // ESC to close
      document.addEventListener('keydown', (ev) => {
        if (ev.key === 'Escape') {
          const isOpen = modalEl.classList.contains('show') && modalEl.style.display !== 'none';
          if (isOpen) closeRrModal(modalEl);
        }
      });
    }

    // backdrop click
    backdrop.onclick = () => closeRrModal(modalEl);
  }

  function closeRrModal(modalEl) {
    if (!modalEl) return;
    modalEl.classList.remove('show');
    modalEl.style.display = 'none';
    modalEl.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('modal-open');
    document.body.style.overflow = '';

    const backdrop = document.getElementById('rrModalBackdrop');
    if (backdrop) {
      backdrop.remove();
    }

    if (modalEl && modalEl._rrParticleAnim) {
      cancelAnimationFrame(modalEl._rrParticleAnim);
      modalEl._rrParticleAnim = null;
    }
  }

  function getNivelParticleColor(nivel) {
    switch ((nivel || '').toLowerCase()) {
      case 'favorito':
        return { r: 255, g: 215, b: 0 };
      case 'elite':
        return { r: 220, g: 20, b: 60 };
      case 'legado':
        return { r: 192, g: 192, b: 192 };
      case 'presilha':
        return { r: 50, g: 205, b: 50 };
      default:
        return { r: 249, g: 115, b: 22 };
    }
  }

  function setupCompetitorModalParticles(modalEl) {
    const canvas = modalEl.querySelector('.competitor-modal__canvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    const contentEl = modalEl.querySelector('.modal-content');
    if (!contentEl) return;
    const nivel = modalEl.querySelector('#modalCompetitorCard')?.dataset?.nivel || '';
    const color = getNivelParticleColor(nivel);
    contentEl.style.setProperty('--particle-r', color.r);
    contentEl.style.setProperty('--particle-g', color.g);
    contentEl.style.setProperty('--particle-b', color.b);
    let particles = [];

    function resizeCanvas() {
      const rect = contentEl.getBoundingClientRect();
      canvas.width = rect.width;
      canvas.height = rect.height;
    }

    function createParticles() {
      particles = [];
      const count = Math.min(70, Math.floor((canvas.width * canvas.height) / 18000));
      for (let i = 0; i < count; i++) {
        particles.push({
          x: Math.random() * canvas.width,
          y: Math.random() * canvas.height,
          size: Math.random() * 2 + 0.6,
          speedX: (Math.random() - 0.5) * 0.45,
          speedY: (Math.random() - 0.5) * 0.45,
          opacity: Math.random() * 0.4 + 0.15
        });
      }
    }

    function draw() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      particles.forEach(p => {
        p.x += p.speedX;
        p.y += p.speedY;
        if (p.x < 0 || p.x > canvas.width) p.speedX *= -1;
        if (p.y < 0 || p.y > canvas.height) p.speedY *= -1;

        ctx.fillStyle = `rgba(${color.r}, ${color.g}, ${color.b}, ${p.opacity})`;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
        ctx.fill();
      });

      for (let i = 0; i < particles.length; i++) {
        for (let j = i + 1; j < particles.length; j++) {
          const dx = particles[i].x - particles[j].x;
          const dy = particles[i].y - particles[j].y;
          const distance = Math.sqrt(dx * dx + dy * dy);
          if (distance < 120) {
            const opacity = 0.18 * (1 - distance / 120);
            ctx.strokeStyle = `rgba(${color.r}, ${color.g}, ${color.b}, ${opacity})`;
            ctx.lineWidth = 0.5;
            ctx.beginPath();
            ctx.moveTo(particles[i].x, particles[i].y);
            ctx.lineTo(particles[j].x, particles[j].y);
            ctx.stroke();
          }
        }
      }

      modalEl._rrParticleAnim = requestAnimationFrame(draw);
    }

    cancelAnimationFrame(modalEl._rrParticleAnim || 0);
    resizeCanvas();
    createParticles();
    draw();

    if (!modalEl._rrParticleResizeBound) {
      modalEl._rrParticleResizeBound = true;
      window.addEventListener('resize', () => {
        if (!modalEl.classList.contains('show')) return;
        resizeCanvas();
        createParticles();
      });
    }
  }

  // Tratamento de clique em Ver Todas
  console.log('[DEBUG] [DEBUG] Procurando botões .verTodasBtn...');
  const verTodosBtns = document.querySelectorAll('.verTodasBtn');
  console.log(`[DEBUG] [DEBUG] Encontrados ${verTodosBtns.length} botões .verTodasBtn`);
  
  verTodosBtns.forEach((btn, index) => {
    console.log(`[DEBUG] [DEBUG] Adicionando listener ao botão ${index + 1}/${verTodosBtns.length}`);
    btn.addEventListener('click', e => {
      console.log('[OK] [DEBUG] Botão "Ver Mais" CLICADO!', {
        competitorId: btn.dataset.id,
        competitorNome: btn.dataset.nome,
        isPremium: btn.dataset.premium === '1'
      });
      
      const premium = btn.dataset.premium === '1';
      console.log('[DEBUG] [DEBUG] Chamando ensureCompetitorModal()...');
      const modalEl = ensureCompetitorModal();
      console.log('[OK] [DEBUG] Modal element obtido:', modalEl ? 'SIM' : 'NÃO');
      
      const nivel = btn.closest('[data-nivel]')?.dataset.nivel || '';
      console.log('[DEBUG] [DEBUG] Nível do competidor:', nivel);

      // Preencher card do competidor
      console.log('[DEBUG] [DEBUG] Preenchendo dados do modal...');
      const cardEl = modalEl.querySelector('#modalCompetitorCard');
      console.log('[DEBUG] [DEBUG] Card element:', cardEl ? 'SIM' : 'NÃO');
      cardEl.dataset.nivel = nivel;
      modalEl.querySelector('#modalCardFoto').src = btn.dataset.foto;
      modalEl.querySelector('#modalCardNome').textContent = btn.dataset.nome;
      const pontosEl = modalEl.querySelector('#modalCardPontos');
      const pontosValue = btn.dataset.pontos || '';
      pontosEl.textContent = pontosValue ? pontosValue : 'EM APURAÇÃO';
      pontosEl.classList.toggle('modal-stat__value--small', !pontosValue);

      // Calcular aproveitamento (boas / (boas + negativas) * 100)
      const boas = parseInt(btn.dataset.countBoa) || 0;
      const negativas = parseInt(btn.dataset.countNegativasTotal) || 0;
      const totalArmadas = Math.max(1, boas + negativas);
      const aproveitamento = Math.round((boas / totalArmadas) * 100);
      modalEl.querySelector('#modalCardAproveitamento').textContent = `${aproveitamento}%`;
      // Preencher stats
      modalEl.querySelector('#modalArmadas').textContent = btn.dataset.armadas || '—';
      modalEl.querySelector('#modalDestrezas').textContent = btn.dataset.destrezas || '0';
      modalEl.querySelector('#modalErros').textContent = btn.dataset.erros || '0';
      modalEl.querySelector('#modalBoas').textContent = btn.dataset.countBoa || '0';

      const lockedEl = modalEl.querySelector('#modalStatsLocked');
      const contentEl = modalEl.querySelector('#modalStatsContent');
      const grids = {
        erros: modalEl.querySelector('#modalStatsGridErros'),
        armadas: modalEl.querySelector('#modalStatsGridArmadas'),
        destrezas: modalEl.querySelector('#modalStatsGridDestrezas'),
        outros: modalEl.querySelector('#modalStatsGridOutros'),
      };
      const topCalloutEl = modalEl.querySelector('#modalPremiumTop');
      const eventsGrid = modalEl.querySelector('#modalStatsEventsGrid');
      const eventsSection = modalEl.querySelector('#modalStatsEvents');

      const eventStatsByCompetitor = @json($eventStatsByCompetitor ?? []);
      const eventLookup = @json($eventLookup ?? []);
      const modalidadeLookup = @json($modalidadeLookup ?? []);

      const rows = {
        erros: [
          ['Pescoço', btn.dataset.countErrouPescoco],
          ['Pata', btn.dataset.countErrouPata],
          ['Top', btn.dataset.countErrouTop],
          ['Garupa', btn.dataset.countGarupaNeg],
          ['Cola', btn.dataset.countColaNeg],
          ['Queimou raia', btn.dataset.countQueimouRaia],
          ['Caiu do cavalo', btn.dataset.countCaiuDoCavalo],
          ['Saiu enrolado', btn.dataset.countSaiuEnrolado],
          ['Dobrada', btn.dataset.countDobrada],
          ['Cabresteou', btn.dataset.countCabresteou],
          ['Duas voltas', btn.dataset.countDuasVoltas],
          ['Boi tirou', btn.dataset.countBoiTirou],
          ['Boi pulou', btn.dataset.countBoiPulou],
          ['Por cima', btn.dataset.countPorCima],
        ],
        armadas: [
          ['Boa', btn.dataset.countBoa],
        ],
        destrezas: [
          ['Limpou garupa', btn.dataset.countLimpouGarupa],
          ['Limpou cola', btn.dataset.countCola],
          ['Limpou cupim', btn.dataset.countCupim],
          ['Limpou cupim (longe)', btn.dataset.countLimpouCupimLonge],
          ['Pescou', btn.dataset.countPescou],
          ['Limpou top', btn.dataset.countLimpouTop],
          ['Limpou top (mão)', btn.dataset.countLimpouTopMao],
          ['Pescou uma aspa', btn.dataset.countPescouUmaAspa],
        ],
        outros: [],
      };

      if (!premium) {
        lockedEl.style.display = 'none';
        contentEl.style.display = '';
        if (topCalloutEl) topCalloutEl.style.display = '';
      } else {
        lockedEl.style.display = 'none';
        contentEl.style.display = '';
        if (topCalloutEl) topCalloutEl.style.display = 'none';
      }

      Object.values(grids).forEach(grid => { if (grid) grid.innerHTML = ''; });
      const shouldBlur = !premium;
      const renderCards = (grid, list) => {
        if (!grid) return;
        grid.innerHTML = list
          .map(([label, value]) => {
            const vNum = parseInt(value || '0', 10) || 0;
            const v = String(vNum);
            const cls = vNum === 0 ? 'stat-zero' : (vNum > 0 ? 'stat-positive' : '');
            const blurCls = shouldBlur ? 'is-locked' : '';
            return `<div class="stats-advanced-card ${cls} ${blurCls}"><span class="stats-advanced-label">${label}</span><span class="stats-advanced-value">${v}</span></div>`;
          })
          .join('');
      };

      renderCards(grids.erros, rows.erros);
      renderCards(grids.armadas, rows.armadas);
      renderCards(grids.destrezas, rows.destrezas);
      renderCards(grids.outros, rows.outros);

      if (eventsGrid && eventsSection) {
        const events = eventStatsByCompetitor[btn.dataset.id] || [];
        if (!events.length) {
          eventsGrid.innerHTML = '<div class="text-muted small">Sem eventos para exibir.</div>';
          eventsSection.style.display = 'none';
        } else {
          eventsSection.style.display = '';
          eventsGrid.innerHTML = events
            .map(evt => {
              const nome = eventLookup[evt.rodeio_id] || `Rodeio #${evt.rodeio_id}`;
              const modalidade = modalidadeLookup[evt.modalidade_id] || 'Modalidade não especificada';
              const divisao = evt.divisao ? ` - ${evt.divisao}` : '';
              const tipoFase = evt.tipo_fase === 'classificatoria' ? 'Classificatória' : 'Final';
              const fase = evt.tipo_fase ? ` (${tipoFase})` : '';
              
              return `<button type="button" class="stats-event-card" data-rodeio-id="${evt.rodeio_id}" data-modalidade-id="${evt.modalidade_id}" data-competitor-id="${btn.dataset.id}" data-nome="${nome}" data-modalidade="${modalidade}" data-pontos="${evt.pontuacao_total}" data-boas="${evt.count_boa}" data-neg="${evt.count_negativas_total}">
                <span class="stats-event-card__title">${nome}</span>
                <span class="stats-event-card__subtitle">${modalidade}${divisao}${fase}</span>
                <span class="stats-event-card__meta">${evt.pontuacao_total} pts</span>
              </button>`;
            })
            .join('');
        }
      }

      console.log('[DEBUG] [DEBUG] Chamando openRrModal()...');
      openRrModal(modalEl);
      console.log('[OK] [DEBUG] Modal aberto!');
      
      // Inicializar tabs do modal
      console.log('[DEBUG] [DEBUG] Inicializando tabs do modal...');
      initializeModalTabs(modalEl, btn.dataset.id);
      console.log('[OK] [DEBUG] Tabs inicializadas!');
    });
  });
  
  console.log('[OK] [DEBUG] Todos os listeners foram adicionados!');

  // ========== CONTROLE DAS TABS DO MODAL ==========
  function initializeModalTabs(modalEl, competitorId) {
    console.log('[DEBUG] [initializeModalTabs] Inicializando tabs para competidor:', competitorId);
    const tabs = modalEl.querySelectorAll('.modal-tab');
    const tabContents = modalEl.querySelectorAll('.modal-tab-content');
    
    console.log(`[DEBUG] [initializeModalTabs] Encontradas ${tabs.length} tabs e ${tabContents.length} tab-contents`);
    
    // Handler de clique nas tabs
    tabs.forEach((tab, index) => {
      console.log(`[DEBUG] [initializeModalTabs] Configurando tab ${index}:`, tab.dataset.modalTab);
      tab.addEventListener('click', () => {
        console.log('[OK] [initializeModalTabs] Tab clicada:', tab.dataset.modalTab);
        const targetTab = tab.dataset.modalTab;
        
        // Remove active de todas
        tabs.forEach(t => t.classList.remove('modal-tab--active'));
        tabContents.forEach(c => c.classList.remove('modal-tab-content--active'));
        
        // Ativa a clicada
        tab.classList.add('modal-tab--active');
        const targetContent = modalEl.querySelector(`#modalTab${targetTab.charAt(0).toUpperCase() + targetTab.slice(1)}`);
        if (targetContent) {
          targetContent.classList.add('modal-tab-content--active');
          
          // Populate tab content based on type
          if (targetTab === 'eventos') {
            populateEventosTab(modalEl, competitorId);
          } else if (targetTab === 'modalidades') {
            populateModalidadesTab(modalEl, competitorId);
          }
        }
      });
    });
  }

  function populateEventosTab(modalEl, competitorId) {
    const grid = modalEl.querySelector('#modalEventosGrid');
    if (!grid || grid.dataset.populated === 'true') return;
    
    const eventStatsByCompetitor = @json($eventStatsByCompetitor ?? []);
    const eventLookup = @json($eventLookup ?? []);
    const modalidadeLookup = @json($modalidadeLookup ?? []);
    
    const events = eventStatsByCompetitor[competitorId] || [];
    
    if (!events.length) {
      grid.innerHTML = '<div class="text-center text-muted">Nenhum evento encontrado.</div>';
      grid.dataset.populated = 'true';
      return;
    }
    
    // Agrupar por evento
    const eventosAgrupados = {};
    events.forEach(evt => {
      const rodeioId = evt.rodeio_id;
      if (!eventosAgrupados[rodeioId]) {
        eventosAgrupados[rodeioId] = {
          id: rodeioId,
          nome: eventLookup[rodeioId] || `Rodeio #${rodeioId}`,
          modalidades: {}
        };
      }
      
      const modalidadeId = evt.modalidade_id || 0;
      if (!eventosAgrupados[rodeioId].modalidades[modalidadeId]) {
        eventosAgrupados[rodeioId].modalidades[modalidadeId] = {
          id: modalidadeId,
          nome: modalidadeLookup[modalidadeId] || 'N/A',
          stats: []
        };
      }
      
      eventosAgrupados[rodeioId].modalidades[modalidadeId].stats.push(evt);
    });
    
    // Renderizar cards de eventos
    grid.innerHTML = Object.values(eventosAgrupados).map(evento => {
      const modalidadesCount = Object.keys(evento.modalidades).length;
      const participacoesTotal = Object.values(evento.modalidades).reduce((acc, mod) => acc + mod.stats.length, 0);
      
      return `
        <div class="modal-event-card" data-evento-id="${evento.id}" data-evento-nome="${evento.nome}">
          <div class="modal-event-card__photo" style="background: linear-gradient(135deg, rgba(249, 115, 22, 0.3), rgba(15, 23, 42, 0.9))">
            <div class="modal-event-card__photo-fallback">
              <i class="fas fa-calendar-alt"></i>
            </div>
          </div>
          <h6 class="modal-event-card__title">${evento.nome}</h6>
          <div class="modal-event-card__meta">
            <span>${modalidadesCount} modalidade(s)</span>
            <span>${participacoesTotal} participações</span>
          </div>
        </div>
      `;
    }).join('');
    
    grid.dataset.populated = 'true';
    
    // Event listeners para os cards
    grid.querySelectorAll('.modal-event-card').forEach(card => {
      card.addEventListener('click', () => {
        const eventoId = parseInt(card.dataset.eventoId);
        const eventoNome = card.dataset.eventoNome;
        showEventoModalidades(modalEl, eventoId, eventoNome, eventosAgrupados[eventoId]);
      });
    });
  }

  function showEventoModalidades(modalEl, eventoId, eventoNome, eventoData) {
    const grid = modalEl.querySelector('#modalEventosGrid');
    const modalidadesSection = modalEl.querySelector('#modalEventModalidades');
    const title = modalEl.querySelector('#modalEventModalidadesTitle');
    const modalidadesGrid = modalEl.querySelector('#modalModalidadesGrid');
    
    grid.style.display = 'none';
    modalidadesSection.style.display = 'block';
    title.textContent = eventoNome;
    
    // Renderizar modalidades
    modalidadesGrid.innerHTML = Object.values(eventoData.modalidades).map(modalidade => {
      const totalPontos = modalidade.stats.reduce((acc, s) => acc + s.pontuacao_total, 0);
      const participacoes = modalidade.stats.length;
      
      return `
        <div class="modal-modalidade-card" data-modalidade-id="${modalidade.id}">
          <h6 class="modal-modalidade-card__title">${modalidade.nome}</h6>
          <div class="modal-modalidade-card__stats">
            <span>${participacoes} participações</span>
            <span>${totalPontos} pts</span>
          </div>
        </div>
      `;
    }).join('');
    
    // Event listeners
    modalidadesGrid.querySelectorAll('.modal-modalidade-card').forEach(card => {
      card.addEventListener('click', () => {
        const modalidadeId = parseInt(card.dataset.modalidadeId);
        showModalidadeStats(modalEl, eventoNome, eventoData.modalidades[modalidadeId]);
      });
    });
    
    // Botão voltar
    modalEl.querySelector('#modalBtnBackToEvents').onclick = () => {
      modalidadesSection.style.display = 'none';
      grid.style.display = 'grid';
    };
  }

  function showModalidadeStats(modalEl, eventoNome, modalidadeData) {
    const modalidadesSection = modalEl.querySelector('#modalEventModalidades');
    const statsSection = modalEl.querySelector('#modalModalidadeStats');
    const title = modalEl.querySelector('#modalModalidadeStatsTitle');
    const details = modalEl.querySelector('#modalModalidadeStatsDetails');
    
    modalidadesSection.style.display = 'none';
    statsSection.style.display = 'block';
    title.textContent = `${eventoNome} - ${modalidadeData.nome}`;
    
    // Agregar stats
    const stats = modalidadeData.stats.reduce((acc, s) => ({
      pontuacao_total: acc.pontuacao_total + s.pontuacao_total,
      count_boa: acc.count_boa + s.count_boa,
      count_negativas_total: acc.count_negativas_total + s.count_negativas_total,
      participacoes: acc.participacoes + 1
    }), { pontuacao_total: 0, count_boa: 0, count_negativas_total: 0, participacoes: 0 });
    
    const totalArmadas = Math.max(1, stats.count_boa + stats.count_negativas_total);
    const aproveitamento = Math.round((stats.count_boa / totalArmadas) * 100);
    
    details.innerHTML = `
      <div class="modal-stats-detail-card">
        <div class="modal-stats-detail-card__header">
          <span class="modal-stats-detail-card__title">Pontuação Total</span>
          <span class="modal-stats-detail-card__value">${stats.pontuacao_total}</span>
        </div>
      </div>
      <div class="modal-stats-detail-card">
        <div class="modal-stats-detail-card__header">
          <span class="modal-stats-detail-card__title">Aproveitamento</span>
          <span class="modal-stats-detail-card__value">${aproveitamento}%</span>
        </div>
        <div class="modal-stats-detail-card__meta">
          <span style="color: #00e676;">${stats.count_boa} boas</span>
          <span style="color: #ff5252;">${stats.count_negativas_total} erros</span>
        </div>
      </div>
      <div class="modal-stats-detail-card">
        <div class="modal-stats-detail-card__header">
          <span class="modal-stats-detail-card__title">Participações</span>
          <span class="modal-stats-detail-card__value">${stats.participacoes}</span>
        </div>
      </div>
    `;
    
    // Botão voltar
    modalEl.querySelector('#modalBtnBackToModalidades').onclick = () => {
      statsSection.style.display = 'none';
      modalidadesSection.style.display = 'block';
    };
  }

  function populateModalidadesTab(modalEl, competitorId) {
    const grid = modalEl.querySelector('#modalModalidadesSummary');
    if (!grid || grid.dataset.populated === 'true') return;
    
    const eventStatsByCompetitor = @json($eventStatsByCompetitor ?? []);
    const modalidadeLookup = @json($modalidadeLookup ?? []);
    
    const events = eventStatsByCompetitor[competitorId] || [];
    
    if (!events.length) {
      grid.innerHTML = '<div class="text-center text-muted">Nenhuma modalidade encontrada.</div>';
      grid.dataset.populated = 'true';
      return;
    }
    
    // Agrupar por modalidade
    const modalidadesAgrupadas = {};
    events.forEach(evt => {
      const modalidadeId = evt.modalidade_id || 0;
      if (!modalidadesAgrupadas[modalidadeId]) {
        modalidadesAgrupadas[modalidadeId] = {
          id: modalidadeId,
          nome: modalidadeLookup[modalidadeId] || 'N/A',
          total_pontos: 0,
          total_boas: 0,
          total_erros: 0,
          participacoes: 0
        };
      }
      
      modalidadesAgrupadas[modalidadeId].total_pontos += evt.pontuacao_total;
      modalidadesAgrupadas[modalidadeId].total_boas += evt.count_boa;
      modalidadesAgrupadas[modalidadeId].total_erros += evt.count_negativas_total;
      modalidadesAgrupadas[modalidadeId].participacoes++;
    });
    
    // Renderizar cards
    grid.innerHTML = Object.values(modalidadesAgrupadas).map(mod => {
      const totalArmadas = Math.max(1, mod.total_boas + mod.total_erros);
      const aproveitamento = Math.round((mod.total_boas / totalArmadas) * 100);
      
      return `
        <div class="modal-modalidade-summary-card">
          <div style="margin-bottom: 1rem;">
            <h6 style="color: #fff; font-weight: 700; margin-bottom: 0.5rem;">${mod.nome}</h6>
            <span style="background: rgba(249, 115, 22, 0.2); color: #f97316; padding: 0.25rem 0.5rem; border-radius: 6px; font-size: 0.75rem; font-weight: 600;">${mod.participacoes} participações</span>
          </div>
          <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.75rem;">
            <div class="stat-item">
              <span class="stat-item__label">Pontos</span>
              <span class="stat-item__value">${mod.total_pontos}</span>
            </div>
            <div class="stat-item">
              <span class="stat-item__label">Aproveitamento</span>
              <span class="stat-item__value">${aproveitamento}%</span>
            </div>
            <div class="stat-item">
              <span class="stat-item__label">Boas</span>
              <span class="stat-item__value stat-item__value--success">${mod.total_boas}</span>
            </div>
            <div class="stat-item">
              <span class="stat-item__label">Erros</span>
              <span class="stat-item__value stat-item__value--danger">${mod.total_erros}</span>
            </div>
          </div>
        </div>
      `;
    }).join('');
    
    grid.dataset.populated = 'true';
  }
    });
  });

  document.addEventListener('click', function (ev) {
    const card = ev.target.closest && ev.target.closest('.stats-event-card');
    if (!card) return;
    const modalEl = ensureEventStatsModal();
    const name = card.getAttribute('data-nome') || 'Evento';
    const modalidade = card.getAttribute('data-modalidade') || '';
    const pontos = parseInt(card.getAttribute('data-pontos') || '0', 10) || 0;
    const boas = parseInt(card.getAttribute('data-boas') || '0', 10) || 0;
    const neg = parseInt(card.getAttribute('data-neg') || '0', 10) || 0;
    const total = Math.max(1, boas + neg);
    const aproveitamento = Math.round((boas / total) * 100);

    modalEl.querySelector('#eventModalTitle').textContent = name;
    const subtitleEl = modalEl.querySelector('#eventModalSubtitle');
    if (subtitleEl) {
      subtitleEl.textContent = modalidade || 'Modalidade não especificada';
    }
    modalEl.querySelector('#eventModalPoints').textContent = pontos;
    modalEl.querySelector('#eventModalAproveitamento').textContent = `${aproveitamento}%`;
    openRrModal(modalEl);
  });
</script>

{{-- Shield Cards CSS --}}
<link rel="stylesheet" href="{{ asset('assets/css/shield-cards.css') }}?v={{ time() }}">
