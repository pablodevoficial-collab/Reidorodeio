
@php
  $categoryCounts = [
    'todos' => count($competitors ?? []),
    'favorito' => collect($competitors ?? [])->filter(fn($c) => strtolower($c->nivel ?? '') === 'favorito')->count(),
    'elite' => collect($competitors ?? [])->filter(fn($c) => strtolower($c->nivel ?? '') === 'elite')->count(),
    'legado' => collect($competitors ?? [])->filter(fn($c) => strtolower($c->nivel ?? '') === 'legado')->count(),
    'presilha' => collect($competitors ?? [])->filter(fn($c) => strtolower($c->nivel ?? '') === 'presilha')->count(),
  ];
  $rrCategories = [
    ['label' => 'Todos', 'key' => 'todos', 'meta' => 'Ver todos'],
    ['label' => 'Favorito', 'key' => 'favorito', 'meta' => 'Top competidores'],
    ['label' => 'Elite', 'key' => 'elite', 'meta' => 'Mais populares'],
    ['label' => 'Ascendente', 'key' => 'legado', 'meta' => 'Profissionais'],
    ['label' => 'Competidor', 'key' => 'presilha', 'meta' => 'Alto nível'],
  ];
@endphp

<div class="rr-stats-submenu-row">

  <div class="rr-stats-search-wrapper rr-stats-search-wrapper--inline">
    <div class="rr-stats-search-form" id="rrStatsSearchForm">
      <input type="search" id="rrStatsSearchInput" placeholder="Nome do competidor:">
      <span class="rr-stats-search-icon" id="rrStatsSearchIcon">
        <svg class="icon-search" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.35-4.35"></path>
        </svg>
        <svg class="icon-close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"></line>
