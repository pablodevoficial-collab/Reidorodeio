<style>
.badge-current-modality {
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(4px);
    color: white;
    padding: 10px 15px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 13px;
    text-transform: uppercase;
    border: 1px solid rgba(255, 255, 255, 0.1);
    display: inline-flex;
    align-items: center;
    gap: 8px;
}

.scoring-btn {
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    border-width: 2px;
}

.scoring-btn:active {
    transform: scale(0.96);
}

.scoring-btn.saving {
    opacity: 0.7 !important;
    pointer-events: none !important;
}

.scoring-btn.saving::after {
    content: "";
    position: absolute;
    width: 14px;
    height: 14px;
    top: 50%;
    right: 10px;
    margin-top: -7px;
    border: 2px solid currentColor;
    border-right-color: transparent;
    border-radius: 50%;
    animation: btn-spin 0.6s linear infinite;
}

@keyframes btn-spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
}

.scoring-btn.success-hit {
    animation: success-pulse 0.5s ease;
    background-color: #28a745 !important;
    color: white !important;
}

@keyframes success-pulse {
    0% { box-shadow: 0 0 0 0 rgba(40, 167, 69, 0.7); }
    70% { box-shadow: 0 0 0 10px rgba(40, 167, 69, 0); }
    100% { box-shadow: 0 0 0 0 rgba(40, 167, 69, 0); }
}

#scoringModal .modal-header {
    border-bottom: none;
    padding-bottom: 0;
}

#scoringModal .modal-content {
    border: none;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
}

.competitor-info-bar {
    background: #f8f9fa;
    border-radius: 12px;
    padding: 15px 20px;
    margin-bottom: 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border: 1px solid #eee;
}

/* Safety: keep modal hidden even if Bootstrap CSS fails to load */
#scoringModal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 2000;
    background: rgba(0,0,0,.55);
    overflow-x: hidden;
    overflow-y: auto;
}
#scoringModal.show {
    display: block;
}

/* Ensure dialog looks like a centered popout even with template CSS */
#scoringModal .modal-dialog {
    margin: 2rem auto;
    max-width: min(1140px, calc(100% - 2rem));
    pointer-events: none;
}

#scoringModal .modal-content {
    pointer-events: auto;
}

/* Keep backdrop behind this modal but above the page */
.modal-backdrop {
    z-index: 1990;
}

/* Fallback: ensure accordion/collapse stays hidden if Bootstrap CSS isn't loaded */
.collapse:not(.show) {
    display: none;
}

/* === Live Transmission UI polish (scoped) === */
:root {
    --lt-surface: rgba(255, 255, 255, 0.06);
    --lt-surface-2: rgba(255, 255, 255, 0.09);
    --lt-border: rgba(255, 255, 255, 0.12);
    --lt-shadow: 0 10px 24px rgba(0, 0, 0, 0.25);
    --lt-radius: 14px;
    --lt-radius-sm: 12px;
    --lt-text: rgba(255, 255, 255, 0.92);
    --lt-muted: rgba(255, 255, 255, 0.65);
}

#competitorsList {
    padding: 10px;
    padding-bottom: 10px;
}

/* Nicer scrolling on Windows */
#competitorsList,
#activityLogs {
    scrollbar-width: thin;
    scrollbar-color: rgba(255,255,255,0.25) transparent;
}
#competitorsList::-webkit-scrollbar,
#activityLogs::-webkit-scrollbar {
    width: 10px;
}
#competitorsList::-webkit-scrollbar-thumb,
#activityLogs::-webkit-scrollbar-thumb {
    background: rgba(255,255,255,0.22);
    border-radius: 999px;
    border: 2px solid transparent;
    background-clip: content-box;
}

/* Accordion items (competitors) */
#competitorsList .accordion {
    display: flex;
    flex-direction: column;
    gap: 10px;
    align-items: flex-start; /* allow cards to shrink */
}

#competitorsList .accordion-item {
    position: relative; /* anchor for popout */
    border: 1px solid var(--lt-border);
    border-radius: var(--lt-radius);
    overflow: visible; /* allow popout to render outside card */
    background: linear-gradient(180deg, var(--lt-surface), rgba(255, 255, 255, 0.03));
    box-shadow: var(--lt-shadow);
    width: fit-content;
    max-width: 100%;
}

#competitorsList .accordion-header {
    margin: 0;
}

/* Competitor header button */
#competitorsList .accordion-button.competitor-toggle {
    background: transparent;
    color: var(--lt-text);
    padding: 12px 14px;
    border: 0;
    box-shadow: none;
    width: auto;
    border-radius: var(--lt-radius);
}

#competitorsList .accordion-button.competitor-toggle:hover {
    background: rgba(255, 255, 255, 0.06);
}

#competitorsList .accordion-button.competitor-toggle:focus {
    outline: none;
    box-shadow: 0 0 0 3px rgba(255, 130, 46, 0.25);
}

/* Remove Bootstrap default caret if present */
#competitorsList .accordion-button::after {
    display: none;
}

#competitorsList .accordion-button .text-muted {
    color: var(--lt-muted) !important;
}

/* Compact text handling */
#competitorsList .competitor-main {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 14px;
}

#competitorsList .competitor-text {
    min-width: 200px;
    max-width: 360px;
}

#competitorsList .competitor-name {
    font-weight: 700;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

#competitorsList .competitor-total {
    font-size: 12px;
    color: var(--lt-muted);
    white-space: nowrap;
}

/* Smooth rotate of the chevron icon */
#competitorsList .competitor-toggle i.las {
    transition: transform 160ms ease;
}
#competitorsList .competitor-toggle[aria-expanded="true"] i.las {
    transform: rotate(180deg);
}

/* Body */
#competitorsList .accordion-body {
    padding: 12px 14px 14px;
    background: rgba(0, 0, 0, 0.12);
    border-top: 1px solid rgba(255,255,255,0.08);
}

/* Keep accordion bodies as templates only (we render them in a floating popout) */
#competitorsList .accordion-collapse {
    display: none !important;
}

/* Score buttons grid */
#competitorsList .accordion-body .row.g-2 {
    margin-left: 0;
    margin-right: 0;
}

#competitorsList .inline-score-btn {
    border-radius: var(--lt-radius-sm);
    border-width: 1px !important;
    padding: 10px 10px !important;
    min-height: 46px;
    gap: 10px;
    box-shadow: none;
    transition: transform 120ms ease, background-color 120ms ease, border-color 120ms ease;
}

#competitorsList .inline-score-btn small {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.2px;
}

#competitorsList .inline-score-btn:active {
    transform: translateY(1px);
}

/* Solid green/red buttons (requested) */
#competitorsList .inline-score-btn.btn-success,
#competitorsList .inline-score-btn.btn-danger,
#ltCompetitorPopout .inline-score-btn.btn-success,
#ltCompetitorPopout .inline-score-btn.btn-danger {
    border-width: 0 !important;
    color: #fff !important;
}

#competitorsList .inline-score-btn.btn-success,
#ltCompetitorPopout .inline-score-btn.btn-success {
    background: #28a745 !important;
}
#competitorsList .inline-score-btn.btn-success:hover,
#ltCompetitorPopout .inline-score-btn.btn-success:hover {
    background: #23923d !important;
}

#competitorsList .inline-score-btn.btn-danger,
#ltCompetitorPopout .inline-score-btn.btn-danger {
    background: #dc3545 !important;
}
#competitorsList .inline-score-btn.btn-danger:hover,
#ltCompetitorPopout .inline-score-btn.btn-danger:hover {
    background: #c82f3e !important;
}

#competitorsList .inline-score-btn .badge,
#ltCompetitorPopout .inline-score-btn .badge {
    font-weight: 800;
    border-radius: 999px;
    padding: 6px 10px;
}

/* Keep badge readable on solid buttons */
#competitorsList .inline-score-btn.btn-success .badge,
#competitorsList .inline-score-btn.btn-danger .badge,
#ltCompetitorPopout .inline-score-btn.btn-success .badge,
#ltCompetitorPopout .inline-score-btn.btn-danger .badge {
    background: rgba(255,255,255,0.92) !important;
    color: rgba(0,0,0,0.85) !important;
}

/* Loading/success feedback for inline buttons (they use the same classes as modal buttons) */
#competitorsList .inline-score-btn.saving {
    opacity: 0.75 !important;
    pointer-events: none !important;
    position: relative;
}
#competitorsList .inline-score-btn.saving::after {
    content: "";
    position: absolute;
    width: 14px;
    height: 14px;
    top: 50%;
    right: 10px;
    margin-top: -7px;
    border: 2px solid currentColor;
    border-right-color: transparent;
    border-radius: 50%;
    animation: btn-spin 0.6s linear infinite;
}

#competitorsList .inline-score-btn.success-hit {
    animation: success-pulse 0.5s ease;
    background-color: rgba(40, 167, 69, 0.22) !important;
    border-color: rgba(40, 167, 69, 0.65) !important;
}

/* Custom score CTA */
#competitorsList .inline-custom-score {
    border-radius: var(--lt-radius-sm);
    padding: 11px 12px;
    box-shadow: none;
}

/* Inline custom score form */
#competitorsList .inline-custom-form {
    padding: 10px 10px 12px;
    border-radius: var(--lt-radius);
    border: 1px solid rgba(255,255,255,0.10);
    background: rgba(255,255,255,0.04);
}

#competitorsList .inline-custom-title {
    font-weight: 800;
    font-size: 12px;
