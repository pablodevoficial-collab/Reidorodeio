    border: 1px solid rgba(255,255,255,0.12);
    color: rgba(255,255,255,0.92);
}

#competitorsList .inline-custom-form .form-control::placeholder {
    color: rgba(255,255,255,0.45);
}

#competitorsList .inline-custom-add {
    border-radius: 12px;
    padding: 9px 10px;
}

/* Search input looks better on dark cards */
#competitorSearch {
    border-radius: 12px;
}

/* === Competitor scoring popout (floating, over everything; no backdrop) === */
#ltCompetitorPopout {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1985; /* below #scoringModal (2000) + .modal-backdrop (1990) */
    pointer-events: none; /* allow clicking page except on panel */
}
#ltCompetitorPopout.show {
    display: block;
}
#ltCompetitorPopout .lt-popout-panel {
    position: fixed;
    width: min(560px, calc(100vw - 24px));
    max-height: min(78vh, 720px);
    overflow: auto;
    border-radius: var(--lt-radius);
    border: 1px solid rgba(255,255,255,0.14);
    background: radial-gradient(900px 420px at 20% 0%, rgba(255,130,46,.14), transparent 55%),
        linear-gradient(180deg, rgba(30, 27, 38, 0.98), rgba(20, 18, 26, 0.98));
    box-shadow: 0 22px 60px rgba(0,0,0,0.55);
    color: var(--lt-text);
    pointer-events: auto;
}

#ltCompetitorPopout .lt-popout-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 12px 14px;
    border-bottom: 1px solid rgba(255,255,255,0.10);
}

#ltCompetitorPopout .lt-popout-title {
    margin: 0;
    font-weight: 900;
    letter-spacing: 0.2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

#ltCompetitorPopout .lt-popout-sub {
    margin: 0;
    font-size: 12px;
    color: var(--lt-muted);
}

#ltCompetitorPopout .lt-popout-close {
    border: 1px solid rgba(255,255,255,0.18);
    background: rgba(255,255,255,0.06);
    color: rgba(255,255,255,0.92);
    width: 36px;
    height: 36px;
    border-radius: 12px;
    font-size: 22px;
    line-height: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
}

#ltCompetitorPopout .lt-popout-undo {
    border: 1px solid rgba(255,255,255,0.18);
    background: rgba(255,255,255,0.06);
    color: rgba(255,255,255,0.92);
    height: 36px;
    border-radius: 12px;
    padding: 0 12px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-weight: 800;
    font-size: 12px;
}

#ltCompetitorPopout .lt-popout-undo:hover {
    background: rgba(255,255,255,0.10);
}

#ltCompetitorPopout .lt-popout-undo.saving {
    opacity: 0.7;
