APP_NAME="Rei do Rodeio"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=America/Sao_Paulo
APP_URL=https://www.reidorodeio.com.br
ASSET_URL=https://www.reidorodeio.com.br

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

BROADCAST_CONNECTION=log
CACHE_STORE=file
FILESYSTEM_DISK=public
PUBLIC_DISK_ROOT=../public_html/storage
PUBLIC_DISK_URL=https://www.reidorodeio.com.br/storage
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_PATH=/
SESSION_DOMAIN=.reidorodeio.com.br
SESSION_SECURE_COOKIE=true

SANCTUM_STATEFUL_DOMAINS=reidorodeio.com.br,www.reidorodeio.com.br
